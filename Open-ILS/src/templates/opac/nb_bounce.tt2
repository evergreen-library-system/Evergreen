[%- USE CGI = CGI_utf8 -%]
<html>
  <head>
    <script>window.location.href='[%- CGI.param('redirect_to') -%]';</script>
  </head>
  <body>
    <p>Your browser should redirect you to your destination automatically; if
      not, please <a href="[% CGI.param('redirect_to') | html %]">click here to
      continue</a>
    </p>
  </body>
<html>
